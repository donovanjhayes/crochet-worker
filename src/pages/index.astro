---
import ProductCard from '../components/ProductCard.astro';
import ContactForm from '../components/ContactForm.astro';

// 1. Fetch the live data from your SonicJS database
// (Make sure your SonicJS server is running in another terminal window!)
const response = await fetch('http://localhost:8787/api/collections/products/content');
const rawData = await response.json();

// 2. Extract the array of products. 
// Headless CMSs usually wrap your items in a "data" property.
const products = rawData.data || []; 

// 3. Define the base URL for your images so Astro knows where to load them from
const CMS_URL = 'http://localhost:8787/api/files/uploads/1ccdbeef-4740-4baf-98ef-1a04a608de63.jpeg';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Cozy Stitches | Crochet Store</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="hero">
      <h1>Cozy Stitches</h1>
      <p>Handmade crochet goods to keep you warm and happy.</p>
    </header>
    
    <main>
    <div class="product-grid">
        {products.map((product) => (
          <ProductCard 
            title={product.title}
            description={product.description}
            imageUrl = 'http://localhost:8787/files/uploads/b04bf9aa-07c6-4078-94f6-b6818e6fec0a.jpeg'
            buyLink={product.buyLink}
          />
        ))}
      </div>
      <ContactForm />
    </main>
  </body>
</html>

<style is:global>
  /* --- GLOBAL MODERN THEME --- */
  :root {
    --bg-color: #faf9f6; 
    --text-main: #2d3748; 
    --text-muted: #718096; 
    --accent: #8ba888; 
    --accent-hover: #718c6f; 
    --card-bg: #ffffff;
    --radius: 12px;
    
    /* Define our new fonts */
    --font-heading: 'Fraunces', serif;
    --font-body: 'Inter', system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    /* Apply body font to the whole page */
    font-family: var(--font-body);
    background-color: var(--bg-color);
    color: var(--text-main);
    line-height: 1.6;
  }

  /* Apply the playful serif font to all headings */
  h1, h2, h3 {
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: -0.5px;
    color: var(--text-main); /* Ensures headings pop */
  }

  .hero {
    text-align: center;
    padding: 4rem 1rem 2rem;
  }

  .hero h1 {
    font-size: 3.5rem; /* Made slightly larger to show off the font! */
    margin-bottom: 0.5rem;
    color: var(--accent);
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    padding: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }
</style>